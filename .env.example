# Copy this file to .env and replace with real values.
# Never commit production secrets.

# Twilio credentials (required)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM=+1XXXXXXXXXX

# Service port (HTTP + UDP)
PORT=18180

# Anti-Spam Cooldown (Seconds to wait before sending another SMS to the same number)
# Default is 60 seconds if this value is omitted 
SMS_COOLDOWN_SECONDS=60

# Optional UDP recipients (You can add TWILIO_TO3, TWILIO_TO4, etc. dynamically)
TWILIO_TO1=+56XXXXXXXXX
TWILIO_TO2=

# Legacy var present in code but not used in active flow
TWILIO_TO=
